# Exceptions to above rules
!**/ios/**/default.mode1v3
!**/ios/**/default.mode2v3
!**/ios/**/default.pbxuser
!**/ios/**/default.perspectivev3

# Database files (user progress, may contain user data)
user_progress.db
*.db-journal
*.db-shm
*.db-wal

# Assets (keep the source database file, but ignore user copies)
# Note: italy_quiz.db in assets/ should be tracked, but user copies in device directories should not
!assets/italy_quiz.db

# Environment variables
.env
.env.local

